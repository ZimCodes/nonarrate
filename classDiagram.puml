@startuml
hide empty members
'Validator
abstract class IValidatorChain {
	#nextValidator: IValidatorChain
	{abstract} +isValid(line:str): bool
	+setNextValidator(chain: IValidatorChain)
}
abstract class IValidatorChainSolo {
	#validatePat: Regex
  +isValid(line:str): bool
}
'Ex: "Narrator" "Player listen to me..."
class CharacterStrategy
class BasicCharacterStrategy
'Ex: "" "Winds furosiously blew to the east."
class CharacterNoneStrategy

class ObjectStrategy {
	{static}#speakerObjects: Set<str>
  {static}-objNamePat: Regex
  {static}#charItemPats: List<Regex>
  {static}#validatePat: Regex
  {static}-initCharItem(char_item: str|list<str>|None)
  {static}+reset()
	+defineSpeakers(fileInfos: List<FileInfo>)
  +isValid(line:str): bool
}
'Ex: narr "Player, please select this choice."
class BasicObjectStrategy
'Ex: define narr = Character(None)
class ObjectNoneItemStrategy
'Ex: define narr = Character("Mi", what_italic=True)
class ItalicObjectStrategy
class NullStrategy
class ObjectVarStrategy

class ItalicStrategy
class ParenthesisStrategy
'Ex: "{i}What am I thinking! I can't do that... right?{/i}" OR
'Ex: "Player" "{i}What am I thinking! I can't do that... right?{/i}"
class CustomTextTagStrategy
'Ex: "Marco jumps over the fence, scrapping his arm in the process"
class BasicStrategy
class ExpressionCueStrategy
'Ex: mc "*smiles*"
class ExpressionCueAsteriskStrategy
'Ex: mc "~yawns~"
class ExpressionCueTildaStrategy
'Ex: mc "......."'
class OnlyPunctuationStrategy

'Triple quote validators
class TQExpressionCueStrategy
class TQExpressionCueAsteriskStrategy
class TQExpressionCueTildaStrategy
class TQItalicStrategy
class TQOnlyPunctuationStrategy
class TQParenthesisStrategy
class TQTextTagStrategy

'File Descriptors
class Reader {
  +readLines(fileURL: Union[str,Path]): FileInfo
  +walkFiles(rootDir:str): List<str>
}
class Writer {
  +writeLines(fileInfo:FileInfo)
  {static}+backupDir(filePaths:List<str>,backupDirPath:Path)
  {static}+printStats(total_lines:int, total_cleaned:int)
}
class Deleter {
	+delete(fileURL: str)
}

'File Filters
class FileFilter {
  #invalid_folders: Set<str>
  #invalid_files: Set<str>
  +is_invalid_folder(dirPath:str): bool
  +is_valid_file(fileName:str): bool
}
class RenpyFilter {
  #invalid_globs: Set<str>
  -fileExt:str
  +is_valid_file(fileName:str): bool
  -hasPassedLiteral(fileName:str): bool
  -hasPassedGlob(fileName:str): bool
}

'ThreadExecutors
class  FileExecutor <<Singleton>>{
	{static}+fileLines(reader:Reader,arg:Namespace): List<FileInfo>
  {static}+writeFiles(writer:Writer,fileInfos:List<FileInfo>)
  {static}+fix_errors(error_txt:Path,reader:Reader)
  {static}-fixFunc(errors: List<RenpyError>)
}

'Handler Info
class AtlInfo {
  +isAtl: bool
  +indentNum: int
  -altPat: Regex
  {static}+isBlock(stripLine:str): bool
}
class LineInfo {
  #stripLine: str
  #isTripleQuote: bool
  #isTripleQuoteEnd: bool
  #hasTripleQuote: bool
  #isMenu: bool
  +setup(line:str)
  {static}-startswitchTripleQuote(stripLine:str): bool
  {static}-hasTripleQuote(stripLine:str): bool
  {static}-endswithTripleQuote(stripLine:str): bool
  {static}-isChoiceMenu(stripLine:str): bool
}
class MultiLineInfo {
  +multiType: MultiLineType
  +isChoiceMenu: bool
  #lines: List<str>
  +clear()
  +append(line:str)
  +isEmpty(): bool
  +reset()
}
class PrevInfo {
  +line: str
  +reset()
}
class PrevMultiInfo {
  #multiInfo: MultiLineInfo
  +isNarr: bool
  +appendLine(line:str)
  +clearList()
  +isEmptyList(): bool
  +getLines(): List<str>
  +reset()
}
class PrevIndentInfo {
  #indentNum: int
  #hasReset: bool
  +reset()
}
class PauseInfo {
  -isPause: bool
  -isPrevPause: bool
  +setPause(value:bool)
  +isDuplicate(): bool
  +snapshotPauseState()
}

'Narrator Handler
class  NarratorHandler <<Singleton>>{
  {static}+PAUSE_STATEMENTS:tuple<str>
  {static}-closingPat: Regex
  {static}-totalLines: int
  {static}-totalCleanedLines: int
  {static}+remove(fileInfos:List<FileInfo>,args:Namespace): List<Dictionary<str,List<str>>>
  {static}+getIdentNum(line:str):int
  {static}-isComment(line:str):bool
  {static}-isClosing(line:str):bool
  {static}-resetLineStats()
  {static}+lineStats(): Tuple<int,int>
  {static}-correctIndent(fileInfos:List<FileInfo>): List<FileInfo>
  {static}-pauseFilter(fileInfos:List<FileInfo>): List<FileInfo>
}
class  ErrorFixer {
  {static}-destPat: Regex
  {static}-typePat: Regex
  {static}-lineNumPat: Regex
  {static}-projectDir:Union[str,None]
  +fix(errors: List<RenpyError>,reader:Reader,writer:Writer,deleter:Deleter)
  {static}+getErrors(errors_txt:Path, reader:Reader): Dictionary<str,List<RenpyError>>
  {static}-addError(errors: Dictionary<str,List<RenpyError>>,error: RenpyError)
  {static}-getError(line:str): RenpyError
  {static}-dedentLines(lines:List<str>,startIndex: int,startIndent: Union[int,None]): List<str>
  {static}-reverseDedentLines(lines:List<str>,startIndex: int): List<str>
}
dataclass FileInfo {
  +url:str
  +lines: List<str>
}
dataclass RenpyError {
  +line_num:Union[int,None]
  +file_loc:Union[str,None]
  +category:Union[str,None]
}

'Argument Classes
class CLIParser {
    -parser: ArgumentParser
    -setup()
    -initParser()
    -configureOpts()
    +getArgs(commands:str)
}
class ArgChecker {
    {static}+checkArgs(args: Namespace)
    {static}-validateFolderOrFileArg(folderOrFileArg: Path)
}
class ArgAssembler {
  {static}-validators: Dictionary<str,Type>
  {static}-tqValidators: List<Type>
  {static}+assemble(args:Namespace)
  {static}-convertFilters(args:Namespace)
  {static}-escape(args:Namespace, arg_filter_val: Union<List<str>,None>>): Union<str,List<str>,None>
  {static}-nargFilter(validator:Union<IValidatorChain,None>,arg_filter: Union<str,List<str>,None>,filterName:str): IValidatorChain
  {static}-tripleQuoteFilter(args:Namespace)
  {static}-tripleQuoteNArgs(validator:Union<IValidatorChain,None>, argFilter: Union<str,List<str>,None>,filterType: Type)
}

enum FilterTag {
  BASIC_CHAR
  NONE_CHAR
  ITALIC_NARR
  PARENTHESIS_NARR
  BASIC_NARR
  BASIC_CHAR_OBJ
  NONE_CHAR_OBJ
  EXPRESSION_CUES
  ONLY_PUNCTUATIONS
  NO_CUSTOM_CHAR_OBJS
  NO_CUSTOM_TEXT_TAGS
  NO_CUSTOM_CHARS
}

enum MultiLineType {
  NONE
  ONE_QUOTE
  TRIPLE_QUOTE 
  VALID_TRIPLE_QUOTE
}

'Invalid Filters Relations
FileFilter <|-- RenpyFilter

'Info Relations
PrevInfo <|-- PrevIndentInfo
PrevInfo <|-- PrevMultiInfo
MultiLineInfo o-- PrevMultiInfo

'Handler Relations
NarratorHandler --> PrevIndentInfo : uses
NarratorHandler --> PrevMultiInfo : uses
NarratorHandler --> AltInfo : uses
NarratorHandler --> LineInfo : uses
NarratorHandler --> PauseInfo : uses

'Validator Relations
IValidatorChain <|-- ObjectStrategy
IValidatorChain <|-- IValidatorChainSolo
IValidatorChainSolo <|-- BasicStrategy
IValidatorChainSolo <|-- CustomTextTagStrategy
IValidatorChainSolo <|-- ParenthesisStrategy
IValidatorChainSolo <|-- ItalicStrategy
IValidatorChainSolo <|-- CharacterStrategy
IValidatorChainSolo <|-- CharacterNoneStrategy
IValidatorChainSolo <|-- ExpressionCueStrategy
IValidatorChainSolo <|-- NullStrategy
IValidatorChainSolo <|-- OnlyPunctuationStrategy
IValidatorChainSolo <|-- TQExpressionCueStrategy
IValidatorChainSolo <|-- TQItalicStrategy
IValidatorChainSolo <|-- TQOnlyPunctuationStrategy
IValidatorChainSolo <|-- TQParenthesisStrategy
IValidatorChainSolo <|-- TQTextTagStrategy
TQExpressionCueStrategy <|-- TQExpressionCueAsteriskStrategy
TQExpressionCueStrategy <|-- TQExpressionCueTildaStrategy
ExpressionCueStrategy <|-- ExpressionCueAsteriskStrategy
ExpressionCueStrategy <|-- ExpressionCueTildaStrategy
CharacterStrategy <|-- BasicCharacterStrategy
ObjectStrategy <|-- BasicObjectStrategy
ObjectStrategy <|-- ObjectNoneItemStrategy
ObjectStrategy <|-- ItalicObjectStrategy
ObjectStrategy <|-- ObjectVarStrategy

'Argument Relations
ArgChecker ..> CLIParser : uses
ArgAssembler ..> CLIParser : uses
@enduml
